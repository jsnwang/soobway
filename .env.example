# MTA BusTime API key — get one at https://bt.mta.info/wiki/Developers/Index
# (Subway GTFS-RT feeds are public and require no key)
BUSTIME_API_KEY=your_bustime_api_key_here

# Display mode: 'terminal' (default, works anywhere) or 'matrix' (Raspberry Pi + LED panel)
DISPLAY_MODE=terminal

# How often to refresh arrival data (seconds)
REFRESH_INTERVAL=30

# Matrix hardware (only used when DISPLAY_MODE=matrix)
MATRIX_ROWS=32
MATRIX_COLS=64
MATRIX_CHAIN=1
MATRIX_BRIGHTNESS=50
